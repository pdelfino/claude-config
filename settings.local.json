{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(*)",
      "mcp__*",
      "mcp__clojure-mcp__list_nrepl_ports",
      "mcp__clojure-mcp__clojure_inspect_project",
      "mcp__clojure-mcp__clojure_eval",
      "mcp__ide__getDiagnostics",
      "mcp__clojure-mcp__clojure_edit",
      "Bash(mkdir -p ~/.claude/hooks ~/.claude/state)",
      "Bash(/bin/ls -la ~/.claude/hooks ~/.claude/state)",
      "Bash(date +%s)",
      "Bash(/bin/ls -la ~/.claude/hooks/announce-new-documents.sh ~/.claude/state/documents-last-seen)",
      "Bash(bash ~/.claude/hooks/announce-new-documents.sh)",
      "Bash(echo \"=== exit: $? ===\")",
      "Bash(/bin/cat ~/.claude/state/hook-debug.log)",
      "Bash(/bin/cat ~/.claude/state/documents-last-seen)",
      "Bash(rm -f ~/.claude/state/hook-debug.log)",
      "Bash(/bin/cat ~/.claude/hooks/announce-new-documents.sh)",
      "Bash(echo \"\\(script exit: $?\\)\")"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(deploy:*)",
      "Bash(npm run deploy:*)",
      "Bash(yarn deploy:*)",
      "Bash(pnpm deploy:*)",
      "Bash(vercel:*)",
      "Bash(netlify deploy:*)",
      "Bash(firebase deploy:*)",
      "Bash(aws deploy:*)",
      "Bash(gcloud app deploy:*)",
      "Bash(kubectl apply:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "clojure-mcp-frontend",
    "clojure-mcp-backend"
  ]
}
