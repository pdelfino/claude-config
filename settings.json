{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Task",
      "Skill",
      "mcp__chrome-devtools__*"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(gh pr merge*)",
      "Bash(*deploy*)",
      "Bash(*npm publish*)",
      "Bash(*yarn publish*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /Users/pedro/.claude/sounds/gong.wav &"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /Users/pedro/.claude/sounds/knock.wav &"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && mkdir -p .claude && { echo \"# Session-end snapshot\"; echo \"Last updated: $(date -Iseconds)\"; echo; echo \"## Branch\"; git branch --show-current; echo; echo \"## Last 10 commits\"; git log --oneline -n 10; echo; echo \"## Uncommitted changes (short)\"; git status --short; } > .claude/session-end-state.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$HOME/.claude/state\" && date +%s > \"$HOME/.claude/state/documents-last-seen\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/announce-new-documents.sh\""
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}
